# Config Firebase WEB (valeurs PUBLIQUES — jamais de clé privée / compte de service ici).
# La clé apiKey web n'est PAS un secret : c'est un identifiant client, protégé par les
# règles Firestore/Storage + App Check. Ce fichier .env réel est gitignoré.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=<projectId>.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=<projectId>
# Bucket Storage DÉDIÉ à hr360 (projet partagé) — ex. hr360.firebasestorage.app
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# --- Isolation dans un projet Firebase PARTAGÉ ---
# Base Firestore NOMMÉE dédiée à hr360 (jamais '(default)', réservée à l'autre app).
# Lors d'une migration vers un projet DÉDIÉ, repasser à '(default)'.
VITE_FIREBASE_DB_ID=hr360
# Région unique de déploiement (fonctions callables + ressources).
VITE_FIREBASE_REGION=europe-west1

# Utiliser les émulateurs en dev local.
VITE_USE_EMULATORS=true

# --- App Check (recommandé en production) ---
# Clé de site reCAPTCHA v3 (PUBLIQUE, ok à embarquer). Vide = App Check désactivé.
# À activer aussi côté console Firebase (enforcement) pour Firestore/Functions/Storage.
VITE_APPCHECK_SITE_KEY=
# En dev, un jeton de debug (généré par le SDK) évite reCAPTCHA. Laisser vide en prod.
VITE_APPCHECK_DEBUG_TOKEN=
