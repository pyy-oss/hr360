{
  "name": "neurones-hr-360",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "emulators": "firebase emulators:start",
    "test": "vitest run",
    "test:rules": "firebase emulators:exec --only firestore \"vitest run tests/\"",
    "deploy": "npm run build && firebase deploy",
    "test:functions": "firebase emulators:exec --only firestore,auth --project neurones-hr-360-test \"cd functions && npm run test\""
  },
  "dependencies": {
    "@tanstack/react-query": "^5.40.0",
    "firebase": "^10.12.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-hook-form": "^7.51.0",
    "react-router-dom": "^6.23.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^3.0.4",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "firebase-tools": "^13.11.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vitest": "^1.6.0"
  }
}